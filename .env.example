API_PORT=8000
# PostgreSQL — pgAdmin4 + migrate script (Node)
PGHOST=localhost
PGPORT=5432
PGDATABASE=practice_certificate
PGUSER=postgres
PGPASSWORD=your_password_here

# FastAPI / Alembic
DATABASE_URL=postgresql+asyncpg://postgres:your_password_here@localhost:5432/practice_certificate
CORS_ORIGINS=http://localhost:5173

# API server (npm run api)
API_HOST=127.0.0.1

# Vite dev proxy → FastAPI (port phải khớp API_PORT)
VITE_API_PROXY=http://127.0.0.1:8000

# Auth (generate JWT_SECRET: openssl rand -hex 32)
JWT_SECRET=change-me-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
# First registration with this email becomes admin (then remove)
# BOOTSTRAP_ADMIN_EMAIL=admin@example.com

# Dev sample logins (npm run seed:users): student|teacher|admin @example.com / Sample123!

# Optional
# APP_NAME=practice-certificate-api
# DEBUG=false
